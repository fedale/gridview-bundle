{#
  Optional {localeSwitcher} layout token. Renders the bundle's own language
  toggle ONLY when i18n.lang_switcher is enabled — when the host page already has
  a switcher, leave this off and let that switcher drive the grid (DOM event /
  <html lang> / the window.GridviewI18n API). See the i18n.* bundle config.
#}
{% if gv_lang_switcher() %}
<button type="button" class="gv-btn gv-locale-switcher"
        data-controller="gridview-locale-switcher"
        data-action="gridview-locale-switcher#toggle">
    🌐 <span data-gridview-locale-switcher-target="label"></span>
</button>
{% endif %}
