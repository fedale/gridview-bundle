{% set gvResponsive = gridview.options.responsive|default(false) %}
{% if gvResponsive %}<div class="gv-resp-wrap" data-gridview-responsive-target="wrap">{% endif %}
<table {{ gridview.regionAttr('dataview')|options }} data-gv="{{ gridview.key }}">
    {% if gridview.options.caption %}
        <caption>{{ gridview.options.caption }}</caption>
    {% endif %}
    {# thead/filter/tbody/tfoot/empty are internals of the table strategy, not
       top-level layout vocabulary, so they are included by path from within the
       strategy rather than dispatched as blocks. #}
    {% for section in gridview.parseLayout('dataview') %}
        {% include '@FedaleGridview/gridview/sections/dataview/' ~ section ~ '.html.twig' ignore missing %}
    {% endfor %}
</table>
{# Apply the user's saved column visibility before paint, mirroring the
   visibility controller's _restore(). The controller only runs once the
   deferred Stimulus bundle has connected, so without this the server-rendered
   (all-visible) columns flash before the hidden ones are removed. Inline
   display:none on the cells (not a global stylesheet rule) so a later
   toggle-on — which clears the inline style — restores the column. #}
<script>(function(){try{var k={{ gridview.key|json_encode|raw }};var s=sessionStorage.getItem('gv-vis-'+k);if(!s)return;var st=JSON.parse(s);for(var i in st){if(st[i]===false){document.querySelectorAll('table[data-gv="'+k+'"] [data-col-key="'+i+'"]').forEach(function(c){c.style.display='none';});}}}catch(e){}})();</script>
{% if gvResponsive %}</div>{% endif %}
