{#
  Default full-page wrapper for CRUD forms (crud.mode = 'page'). Extends the app
  base (override with `pageBase`), and prints the already-rendered form HTML.
  For crud.mode = 'custom' the host app supplies its own template via
  crud.pageTemplate instead of this one.
#}
{% extends pageBase|default('base.html.twig') %}

{% block title %}{{ pageTitle|default('') }}{% endblock %}

{% block body %}
    <div class="gv-crud-page">
        <div class="gv-crud-page__header">
            {% if pageTitle is defined and pageTitle %}<h1 class="gv-crud-page__title">{{ pageTitle }}</h1>{% endif %}
            {# Action buttons next to the title when the form drops its in-form submit. #}
            {% if formActionsInHeader|default(false) and formId|default('') is not empty %}
                <div class="gv-crud-page__actions">
                    {% include '@FedaleGridview/crud/_form_actions.html.twig' %}
                </div>
            {% endif %}
        </div>
        {{ formHtml|raw }}
    </div>
{% endblock %}
