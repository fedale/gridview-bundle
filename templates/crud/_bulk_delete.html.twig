{#
  Bulk-delete confirmation shown in the CRUD modal. POSTs to $action with the
  CSRF token; the selected ids are appended to the action URL by the
  gridview-selection controller before the modal is opened.
#}
<div class="gv-bulk-delete">
    <p class="gv-form-intro">{{ 'crud.bulk_delete_confirm'|trans({'%count%': '<strong>' ~ count ~ '</strong>'}, 'GridviewBundle')|raw }}</p>

    <form method="post" action="{{ action }}" data-action="submit->gridview-crud#submit">
        <input type="hidden" name="_token" value="{{ token }}">
        <div class="gv-form-actions">
            <button type="button" class="{{ gridview.cls('btn') }}" data-action="gridview-crud#close" {{ gv_i18n('crud.cancel') }}>{{ 'crud.cancel'|trans({}, 'GridviewBundle') }}</button>
            <button type="submit" class="{{ gridview.cls('btn.danger') }}">{{ 'crud.delete_count'|trans({'%count%': count}, 'GridviewBundle') }}</button>
        </div>
    </form>
</div>
