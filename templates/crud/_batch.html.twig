{#
  Batch-update form shown in the CRUD modal. Each batchUpdate column renders an
  "apply" checkbox + its value field; only checked fields are applied to the
  selected rows. The selected ids are appended to $action by the
  gridview-selection controller. CSRF is the form's own token (rendered by form_end).
#}
<div class="gv-batch">
    <p class="gv-form-intro gv-muted">
        {{ 'bulk.batch_intro'|trans({'%count%': '<strong>' ~ count ~ '</strong>'}, 'GridviewBundle')|raw }}
    </p>

    {{ form_start(form, {'action': action, 'attr': {'data-action': 'submit->gridview-crud#submit'}}) }}
        {% for child in form %}
            {% if child.vars.name starts with 'enable_' %}
                {% set valueName = child.vars.name|replace({'enable_': ''}) %}
                <div class="gv-batch-row">
                    <div class="gv-batch-apply">{{ form_widget(child) }}</div>
                    <label>{{ child.vars.label }}</label>
                    <div class="gv-batch-field">{{ form_widget(attribute(form, valueName)) }}</div>
                </div>
            {% endif %}
        {% endfor %}
        <div class="gv-form-actions">
            <button type="button" class="{{ gridview.cls('btn') }}" data-action="gridview-crud#close" {{ gv_i18n('crud.cancel') }}>{{ 'crud.cancel'|trans({}, 'GridviewBundle') }}</button>
            {{ form_widget(form.apply) }}
        </div>
    {{ form_end(form) }}
</div>
